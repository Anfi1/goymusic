{
  "name": "goymusic",
  "version": "4.3.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "GoyMusic Player",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anfi1/goymusic.git"
  },
  "build": {
    "appId": "com.goymusic.app",
    "productName": "GoyMusic",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!test_moods.py"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true,
      "uninstallDisplayName": "GoyMusic",
      "artifactName": "GoyMusic-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Anfi1",
      "repo": "goymusic",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scan": "^0.5.3",
    "react-virtuoso": "^4.18.1"
  }
}
